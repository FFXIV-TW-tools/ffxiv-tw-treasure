# Cloudflare Pages headers — 安全強化 + cache 控制

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://ffxiv-tw-tools-portal.pages.dev https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://ffxiv-tw-tools-portal.pages.dev; img-src 'self' data: https://ffxiv-tw-tools-portal.pages.dev https://xivapi.com; connect-src 'self' https://ffxiv-tw-tools-settings-api.ffxiv-tw-tools.workers.dev https://ffxiv-tw-treasure-room.ffxiv-tw-tools.workers.dev wss://ffxiv-tw-treasure-room.ffxiv-tw-tools.workers.dev https://cloudflareinsights.com; media-src 'self' https://ffxiv-tw-tools-portal.pages.dev; font-src 'self' https://ffxiv-tw-tools-portal.pages.dev data:; frame-ancestors 'none'; base-uri 'self'; form-action 'none'

# img-src 含 xivapi.com → 地圖貼圖（/m/...）；portal → fat-cat sprite（background-image 吃 img-src）

# 工具自家 JS / CSS — max-age=0 + must-revalidate → F5 走 ETag 304，push 完即時更新免硬刷
/*.js
  Cache-Control: public, max-age=0, must-revalidate
/*.css
  Cache-Control: public, max-age=0, must-revalidate
/js/*
  Cache-Control: public, max-age=0, must-revalidate

# 生成資料 JSON — 短 cache + revalidate（版本變動由 ETag 抓出）
/data/*
  Cache-Control: public, max-age=600, must-revalidate
